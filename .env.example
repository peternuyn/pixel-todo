# Copy this file to ".env" (same folder) and fill in real values.
# docker-compose automatically reads ".env". NEVER commit the real .env.
#
#   cp .env.example .env

# --- Database ---
POSTGRES_DB=studyfarm
POSTGRES_USER=studyfarm
# Use a strong, random password in production (not "studyfarm").
POSTGRES_PASSWORD=change-me-to-something-strong

# --- Backend ---
# The public URL where your frontend is served. Used for CORS so the browser
# is allowed to call the API. Example: https://app.leap-and-bound.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
