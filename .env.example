# Copy this file to ".env" (same folder) and fill in real values.
# docker-compose automatically reads ".env". NEVER commit the real .env.
#
#   cp .env.example .env

# --- Database ---
POSTGRES_DB=studyfarm
POSTGRES_USER=studyfarm
# Use a strong, random password in production (not "studyfarm").
POSTGRES_PASSWORD=change-me-to-something-strong

# --- Backend ---
# The public URL where your frontend is served. Used for CORS so the browser
# is allowed to call the API. This must be your Vercel URL (no trailing slash).
# Example: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- HTTPS / reverse proxy (used only by scripts/init-letsencrypt.sh) ---
# The hostname Nginx serves HTTPS for. With no domain of your own, use sslip.io,
# which resolves <ip-with-dashes-or-dots>.sslip.io to that IP automatically:
#   DOMAIN=54.255.149.137.sslip.io
# Email is where Let's Encrypt sends expiry warnings.
DOMAIN=54.255.149.137.sslip.io
EMAIL=you@example.com
